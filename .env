# Pinned image versions
CP_KAFKA_VERSION=7.9.0
CP_SCHEMA_REGISTRY_VERSION=7.9.0
MINIO_VERSION=RELEASE.2025-04-08T15-41-24Z
MINIO_MC_VERSION=RELEASE.2025-04-08T15-39-49Z
NESSIE_VERSION=0.103.3
FLINK_VERSION=1.20.1
SPARK_VERSION=3.5.4
DREMIO_VERSION=25.2

# MinIO credentials / S3-compatible endpoint (used by Flink/Spark/Dremio for S3A access)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://minio:9000
S3_PATH_STYLE_ACCESS=true
WAREHOUSE_BUCKET=warehouse

# Nessie catalog
NESSIE_URI=http://nessie:19120/api/v1
NESSIE_VERSION_STORE_TYPE=ROCKSDB

# Kafka / Schema Registry
KAFKA_BOOTSTRAP=kafka:9092
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# Kafka topics
KAFKA_TOPIC_PRODUCTS=shopify.products
KAFKA_TOPIC_INVENTORY=shopify.inventory
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION=1
KAFKA_TOPIC_RETENTION_MS=604800000

# Host port map
KAFKA_HOST_PORT=29092
SCHEMA_REGISTRY_HOST_PORT=8081
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
NESSIE_HOST_PORT=19120
FLINK_UI_HOST_PORT=8082
DREMIO_UI_HOST_PORT=9047

# Spark compaction loop interval (seconds between compaction runs)
COMPACTION_INTERVAL=600

# Dremio admin credentials and memory limits
DREMIO_ADMIN_USER=admin
DREMIO_ADMIN_PASSWORD=dremio123
DREMIO_MAX_MEMORY_SIZE_MB=4096
DREMIO_MAX_DIRECT_MEMORY_SIZE_MB=2048
